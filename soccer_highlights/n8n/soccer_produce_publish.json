    {
      "parameters": {
        "command": "=# Upload recap.mp4 to public storage so Instagram can ingest it.\n# Example (AWS CLI — add aws-cli to setup if you use S3):\n# aws s3 cp \"{{ $(\"Config\").item.json.base }}\\recap.mp4\" s3://your-bucket/recaps/recap.mp4 --acl public-read && echo https://your-bucket.s3.amazonaws.com/recaps/recap.mp4\n#\n# If you don't need Instagram or have no S3, just echo the pre-set URL:\necho \"{{ $(\"Config\").item.json.public_url }}\""
      },
      "id": "759d86d058234ae6",
      "name": "Host recap for Instagram (optional)",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [1560, 400]
