      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [1120, 400]
    },
    {
      "parameters": {
        "command": "=cd /d \"{{ $(\"Config\").item.json.base }}\" && python captions.py goals.json --recap-url \"{{ $(\"Config\").item.json.public_url }}\""
      },
